# Copy to .env for local development — never commit .env

ANTHROPIC_API_KEY=your_anthropic_api_key

# Local Qdrant (docker compose up qdrant -d)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Qdrant Cloud (required for Render production)
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional — defaults shown
# DATABASE_URL=sqlite:///./pdf_chat.db
# CLAUDE_MODEL=claude-sonnet-4-6
